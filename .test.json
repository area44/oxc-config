{
  "$schema": "https://example.com/schema.json",
  "plugins": [
    "typescript",
    "import",
    "unicorn",
    "react"
  ],
  "rules": {
    "eqeqeq": "error",
    "no-unused-vars": "warn"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/.nuxt/**",
    "**/.svelte-kit/**"
  ]
}
