{
  "name": "@area44/oxfmt-config",
  "version": "0.2.0",
  "description": "Shareable oxfmt configuration",
  "keywords": [
    "config",
    "formatter",
    "oxfmt"
  ],
  "license": "MIT",
  "author": "area44",
  "files": [
    ".oxfmtrc.json",
    "oxfmt.config.ts",
    "oxfmt.config.js",
    "README.md"
  ],
  "type": "module",
  "main": "./.oxfmtrc.json",
  "exports": {
    ".": {
      "types": "./oxfmt.config.ts",
      "import": "./oxfmt.config.js",
      "default": "./.oxfmtrc.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/compile-config.ts oxfmt.config.ts .oxfmtrc.json ../../node_modules/oxfmt/configuration_schema.json oxfmt.config.js",
    "lint": "oxlint -c ../oxlint-config/.oxlintrc.json",
    "fmt": "oxfmt -c .oxfmtrc.json"
  },
  "dependencies": {
    "@area44/oxc-shared-config": "workspace:*"
  },
  "peerDependencies": {
    "oxfmt": ">=0.0.0"
  }
}
