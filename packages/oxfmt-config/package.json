{
  "name": "@area44/oxfmt-config",
  "version": "0.2.2",
  "description": "Shareable oxfmt configuration",
  "keywords": [
    "config",
    "formatter",
    "oxfmt"
  ],
  "license": "MIT",
  "author": "area44",
  "repository": {
    "type": "git",
    "url": "https://github.com/area44/oxc-config.git"
  },
  "files": [
    "oxfmt.config.mjs",
    "README.md"
  ],
  "type": "module",
  "main": "./oxfmt.config.mjs",
  "exports": {
    ".": "./oxfmt.config.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint -c ../oxlint-config/oxlint.config.mjs",
    "fmt": "oxfmt -c oxfmt.config.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@area44/oxc-shared-config": "workspace:*"
  },
  "peerDependencies": {
    "oxfmt": ">=0.0.0"
  }
}
