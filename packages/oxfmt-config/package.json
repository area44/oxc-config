{
  "name": "@area44/oxfmt-config",
  "version": "0.2.3",
  "description": "Shareable oxfmt configuration",
  "keywords": [
    "config",
    "formatter",
    "oxfmt"
  ],
  "license": "MIT",
  "author": "area44",
  "repository": {
    "type": "git",
    "url": "https://github.com/area44/oxc-config.git"
  },
  "files": [
    ".oxfmtrc.json",
    "oxfmt.config.mjs",
    "README.md"
  ],
  "type": "module",
  "main": "./.oxfmtrc.json",
  "exports": {
    ".": {
      "import": "./oxfmt.config.mjs",
      "default": "./.oxfmtrc.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/compile-config.mjs oxfmt.config.mjs .oxfmtrc.json ../../node_modules/oxfmt/configuration_schema.json",
    "lint": "oxlint -c ../oxlint-config/.oxlintrc.json",
    "fmt": "oxfmt -c .oxfmtrc.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@area44/oxc-shared-config": "workspace:*"
  },
  "peerDependencies": {
    "oxfmt": ">=0.59.0"
  }
}
