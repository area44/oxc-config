{
  "name": "@area44/oxfmt-config",
  "version": "1.0.0",
  "description": "Shareable oxfmt configuration",
  "keywords": [
    "config",
    "formatter",
    "oxfmt"
  ],
  "license": "MIT",
  "author": "area44",
  "files": [
    ".oxfmtrc.json",
    "oxfmt.config.ts",
    "README.md"
  ],
  "type": "module",
  "main": "./.oxfmtrc.json",
  "exports": {
    ".": {
      "types": "./oxfmt.config.ts",
      "import": "./oxfmt.config.ts",
      "default": "./.oxfmtrc.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx ../../scripts/compile-config.ts oxfmt.config.ts .oxfmtrc.json https://raw.githubusercontent.com/oxc-project/oxc/main/crates/oxfmt/configuration_schema.json && oxfmt -c .oxfmtrc.json .oxfmtrc.json",
    "lint": "pnpm build && oxlint . || true",
    "format": "pnpm build && oxfmt -c .oxfmtrc.json . --check"
  },
  "peerDependencies": {
    "oxfmt": ">=0.0.0"
  }
}
