{
  "name": "@area44/oxlint-config",
  "version": "0.2.2",
  "description": "Shareable oxlint configuration",
  "keywords": [
    "config",
    "lint",
    "oxlint"
  ],
  "license": "MIT",
  "author": "area44",
  "repository": {
    "type": "git",
    "url": "https://github.com/area44/oxc-config.git"
  },
  "files": [
    "oxlint.config.mjs",
    "README.md"
  ],
  "type": "module",
  "main": "./oxlint.config.mjs",
  "exports": {
    ".": "./oxlint.config.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint -c oxlint.config.mjs",
    "fmt": "oxfmt -c ../oxfmt-config/oxfmt.config.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@area44/oxc-shared-config": "workspace:*"
  },
  "peerDependencies": {
    "oxlint": ">=1.0.0"
  }
}
