{
  "name": "@area44/oxlint-config",
  "version": "0.2.3",
  "description": "Shareable oxlint configuration",
  "keywords": [
    "config",
    "lint",
    "oxlint"
  ],
  "license": "MIT",
  "author": "area44",
  "repository": {
    "type": "git",
    "url": "https://github.com/area44/oxc-config.git"
  },
  "files": [
    ".oxlintrc.json",
    "oxlint.config.mjs",
    "README.md"
  ],
  "type": "module",
  "main": "./.oxlintrc.json",
  "exports": {
    ".": {
      "import": "./oxlint.config.mjs",
      "default": "./.oxlintrc.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/compile-config.mjs oxlint.config.mjs .oxlintrc.json ../../node_modules/oxlint/configuration_schema.json",
    "lint": "oxlint -c .oxlintrc.json",
    "fmt": "oxfmt -c ../oxfmt-config/.oxfmtrc.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@area44/oxc-shared-config": "workspace:*"
  },
  "peerDependencies": {
    "oxlint": ">=1.65.0"
  }
}
