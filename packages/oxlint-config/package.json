{
  "name": "@area44/oxlint-config",
  "version": "1.0.0",
  "description": "Shareable oxlint configuration",
  "keywords": [
    "config",
    "lint",
    "oxlint"
  ],
  "license": "MIT",
  "author": "area44",
  "files": [
    ".oxlintrc.json",
    "oxlint.config.ts",
    "README.md"
  ],
  "type": "module",
  "main": "./.oxlintrc.json",
  "exports": {
    ".": {
      "types": "./oxlint.config.ts",
      "import": "./oxlint.config.ts",
      "default": "./.oxlintrc.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node --experimental-strip-types ../../scripts/compile-config.ts oxlint.config.ts .oxlintrc.json ../../node_modules/oxlint/configuration_schema.json && oxfmt -c .oxlintrc.json .oxlintrc.json",
    "lint": "pnpm build && oxlint -c .oxlintrc.json . || true",
    "format": "pnpm build && oxfmt -c .oxlintrc.json . --check"
  },
  "peerDependencies": {
    "oxlint": ">=1.0.0"
  }
}
