{
  "name": "@area44/oxlint-config",
  "version": "0.2.0",
  "description": "Shareable oxlint configuration",
  "keywords": [
    "config",
    "lint",
    "oxlint"
  ],
  "license": "MIT",
  "author": "area44",
  "files": [
    ".oxlintrc.json",
    "oxlint.config.ts",
    "oxlint.config.js",
    "README.md"
  ],
  "type": "module",
  "main": "./.oxlintrc.json",
  "exports": {
    ".": {
      "types": "./oxlint.config.ts",
      "import": "./oxlint.config.js",
      "default": "./.oxlintrc.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/compile-config.ts oxlint.config.ts .oxlintrc.json ../../node_modules/oxlint/configuration_schema.json oxlint.config.js",
    "lint": "oxlint -c .oxlintrc.json",
    "fmt": "oxfmt -c ../oxfmt-config/.oxfmtrc.json"
  },
  "dependencies": {
    "@area44/oxc-shared-config": "workspace:*"
  },
  "peerDependencies": {
    "oxlint": ">=1.0.0"
  }
}